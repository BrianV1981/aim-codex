{
  "description": "A.I.M. turn-done desktop/popup notify for Codex",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.aim/bin/aim_turn_chime.sh\" stop",
            "timeout": 5,
            "statusMessage": "A.I.M. turn notify"
          }
        ]
      }
    ]
  }
}
